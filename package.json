{
  "name": "song-request-corner",
  "version": "0.1.0",
  "description": "A Feishu-first internal song request bot with NetEase web playback and a local admin panel.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AXing567/SongRequestCorner.git"
  },
  "bugs": {
    "url": "https://github.com/AXing567/SongRequestCorner/issues"
  },
  "homepage": "https://github.com/AXing567/SongRequestCorner#readme",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:admin": "vite --host 127.0.0.1",
    "doctor": "tsx src/doctor.ts",
    "build": "npm run build:server && npm run build:admin",
    "build:server": "tsc -p tsconfig.json",
    "build:admin": "tsc -p tsconfig.admin.json && vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "check": "npm run build && npm run test"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "playwright": "^1.61.1"
  }
}
