# ================================
# Song Request Corner configuration
# ================================

# console: local stdin testing
# feishu: real Feishu bot
BOT_TRANSPORT=console

# mock: deterministic local search/playback
# netease-web: NetEase web search/playback
MUSIC_PROVIDER=mock
PLAYER_ADAPTER=mock

# The displayed bot name used to strip a leading @mention.
BOT_DISPLAY_NAME=点歌机器人

# Comma-separated Feishu open_id values or console user ids.
# Playback management is handled by the local admin page, but this remains useful for future privileged flows.
ADMIN_USER_IDS=admin

# Required when BOT_TRANSPORT=feishu.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Required when MUSIC_PROVIDER/PLAYER_ADAPTER=netease-web.
NETEASE_USER_DATA_DIR=.playwright/netease-profile
NETEASE_HEADLESS=false

# Optional. Use installed Chrome/Edge instead of Playwright-managed Chromium.
# Example:
# CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_EXECUTABLE_PATH=

# LAN admin page.
ADMIN_SERVER_ENABLED=true
ADMIN_SERVER_HOST=0.0.0.0
ADMIN_SERVER_PORT=3333

# Local SQLite play history. Keeps the most recent 7 days and survives restarts.
HISTORY_DB_PATH=.data/play-history.sqlite
